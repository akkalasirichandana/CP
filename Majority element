#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int majorityElement(int arr[], int n) {
    int candidate = 0;
    int count = 0;

    for (int i = 0; i < n; i++) {
        if (count == 0) {
            candidate = arr[i];
            count = 1;
        } else if (arr[i] == candidate) {
            count++;
        } else {
            count--;
        }
    }

    int actual_count = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] == candidate) {
            actual_count++;
        }
    }

    if (actual_count > n / 2) {
        return candidate;
    }

    return -1;
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int result = majorityElement(arr, n);
    printf("%d\n", result);

    return 0;
}    
