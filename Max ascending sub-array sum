#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int maxAscendingSum(int arr[], int n) {
    if (n == 0) return 0;

    int max_sum = arr[0];
    int current_sum = arr[0];

    for (int i = 1; i < n; i++) {
        if (arr[i] > arr[i - 1]) {
            current_sum += arr[i];
        } else {
            if (current_sum > max_sum) {
                max_sum = current_sum;
            }
            current_sum = arr[i];
        }
    }

    if (current_sum > max_sum) {
        max_sum = current_sum;
    }

    return max_sum;
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int result = maxAscendingSum(arr, n);
    printf("%d\n", result);

    return 0;
}
