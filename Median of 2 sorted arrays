#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
#include <iomanip>
using namespace std;
int main() {
    int n, m;
    cin >> n >> m;
    long long arr1[n];
    for (int i = 0; i < n; i++)
        cin >> arr1[i];
    long long arr2[m];
    for (int i = 0; i < m; i++)
        cin >> arr2[i];
    long long merged[n + m];
    int i = 0, j = 0, k = 0;
    while (i < n && j < m) {
        if (arr1[i] <= arr2[j])
            merged[k++] = arr1[i++];
        else
            merged[k++] = arr2[j++];
    }
    while (i < n)
        merged[k++] = arr1[i++];
    while (j < m)
        merged[k++] = arr2[j++];
    int size = n + m;
    if (size % 2 == 1) {
        cout << fixed << setprecision(1) << (double)merged[size / 2];
    } else {
        double median = (merged[size / 2 - 1] + merged[size / 2]) / 2.0;
        cout << fixed << setprecision(1) << median;
    }
   return 0;
}
