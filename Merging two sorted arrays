#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
void mergeSortedArrays(int arr1[], int n, int arr2[], int m) {
    int i = 0, j = 0;
    int first = 1;

    while (i < n && j < m) {
        if (!first) {
            printf(" ");
        }
        first = 0;

        if (arr1[i] <= arr2[j]) {
            printf("%d", arr1[i]);
            i++;
        } else {
            printf("%d", arr2[j]);
            j++;
        }
    }

    while (i < n) {
        if (!first) {
            printf(" ");
        }
        first = 0;
        printf("%d", arr1[i]);
        i++;
    }

    while (j < m) {
        if (!first) {
            printf(" ");
        }
        first = 0;
        printf("%d", arr2[j]);
        j++;
    }
    printf("\n");
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    int arr1[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr1[i]);
    }

    int m;
    if (scanf("%d", &m) != 1) return 0;
    int arr2[m];
    for (int i = 0; i < m; i++) {
        scanf("%d", &arr2[i]);
    }

    mergeSortedArrays(arr1, n, arr2, m);

    return 0;
}
